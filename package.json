{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@11.3.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach(f=>{try{fs.unlinkSync(f)}catch(e){}});const ua=process.env.npm_config_user_agent||'';const execPath=process.env.npm_execpath||'';if(!ua.includes('pnpm/')&&!execPath.toLowerCase().includes('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "dev": "pnpm --filter @workspace/bod-app dev",
    "preview": "pnpm --filter @workspace/bod-app preview",
    "app:build": "pnpm --filter @workspace/bod-app build",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
